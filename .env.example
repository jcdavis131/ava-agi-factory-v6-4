# Copy to .env (gitignored). All values are optional.

# nano | mini | base1b
AVA_PRESET=nano

# Only needed for gated datasets. Every source in configs/sources.yaml is
# ungated, so this can stay empty. bigcode/the-stack-smol is gated:"auto"
# and is deliberately NOT in the registry for that reason.
HF_TOKEN=

# Gate for POST /jspace/intervene. 0 => the endpoint 403s regardless of ?mode.
# Set to 1 only for local research; every intervention is written to
# runs/serve_audit.jsonl.
ENABLE_JSPACE_WRITE=0
